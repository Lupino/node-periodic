{
  "name": "node-periodic",
  "version": "1.6.0",
  "description": "Peridoc task system node client.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transport": {
      "require": "./dist/transport.js",
      "types": "./dist/transport.d.ts"
    }
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run clean && npm run build",
    "test": "npm run build && tape test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lupino/node-periodic"
  },
  "author": "Li Meng Jun <lmjubuntu@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "buffer-equal": "1.0.1",
    "generic-pool": "^3.9.0",
    "int64-buffer": "^1.0.1",
    "js-crc": "^0.2.0",
    "random-string": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "async": "^3.2.6",
    "eslint": "^9.11.1",
    "tape": "^5.9.0",
    "typescript": "^5.9.0"
  }
}
